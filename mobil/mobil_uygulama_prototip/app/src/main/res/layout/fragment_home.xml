<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Konum başlığı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Elazığ, Merkez"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />

            <TextView
                android:id="@+id/tvLastUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 dk önce"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <!-- Trafik Durumu Kartı -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTraffic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚦 Trafik Durumu"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/trafficIndicator"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:background="@color/traffic_green"
                        android:layout_marginEnd="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvTrafficStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yoğunluk: Orta"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/tvTrafficDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ort. Hız: 38 km/s · Yoğunluk: %62"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnTrafficMap"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Haritada Gör" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hava Kalitesi Kartı -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAirQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌫️ Hava Kalitesi"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvAqiScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="72"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/aqi_moderate"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAqiLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Orta"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/tvAqiAdvice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hassas gruplar dışarıyı sınırlasın"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>

                <!-- PM2.5 / CO2 / NO2 chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPm25"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PM2.5: 35"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCo2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CO2: 420"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipNo2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NO2: 28" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Acil Uyarı Banner (normalde GONE) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/error_container"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:id="@+id/tvEmergencyText"
                    android:text="⚠️ Acil Durum"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/error" />

                <Button
                    android:id="@+id/btnEmergencyDetail"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detay"
                    android:textColor="@color/error" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Son Duyurular Başlığı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/recent_announcements"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />

            <TextView
                android:id="@+id/tvSeeAllAnnouncements"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/see_all"
                android:textColor="@color/primary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Duyuru listesi -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAnnouncements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
